{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["DOM", "DOM.Iterable", "ES2020"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": true,
		"jsx": "react-jsx",
		"outDir": "dist",
		"rootDir": "src"
	},
	"include": ["src/**/*"]
}
