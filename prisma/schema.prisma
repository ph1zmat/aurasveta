generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  EDITOR
  ADMIN
}

enum PageKind {
  REGULAR
  HOME
  SYSTEM
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  phone         String?  @unique
  image         String?
  role          UserRole @default(USER)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions         Session[]
  accounts         Account[]
  verifications    Verification[]
  cart             Cart?
  favorites        Favorite[]
  orders           Order[]
  pages            Page[]
  products         Product[]
  compareItems     CompareItem[]
  anonymousSession AnonymousSession?
  pushDevices      PushDevice[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId        String    @map("provider_id")
  providerAccountId String?   @map("provider_account_id")
  accessToken       String?   @map("access_token")
  refreshToken      String?   @map("refresh_token")
  expiresAt         DateTime? @map("expires_at")
  password          String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  accountId             String
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?

  @@unique([providerId, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identifier])
  @@map("verifications")
}

// ---------- Categories ----------

model Category {
  id                    String              @id @default(cuid())
  name                  String
  slug                  String              @unique
  description           String?
  image                 String?
  imagePath             String?             @map("image_path")
  imageOriginalName     String?             @map("image_original_name")
  showInHeader          Boolean             @default(true) @map("show_in_header")
  categoryMode          CategoryMode        @default(MANUAL) @map("category_mode")
  filterKind            CategoryFilterKind? @map("filter_kind")
  filterPropertyId      String?             @map("filter_property_id")
  filterPropertyValueId String?             @map("filter_property_value_id")
  parentId              String?             @map("parent_id")
  parent                Category?           @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: SetNull)
  children              Category[]          @relation("CategoryToCategory")
  products              Product[]
  productsAsRoot        Product[]           @relation("ProductRootCategory")
  productsAsSubcategory Product[]           @relation("ProductSubcategory")
  filterProperty        Property?           @relation("CategoryFilterProperty", fields: [filterPropertyId], references: [id], onDelete: SetNull)
  filterPropertyValue   PropertyValue?      @relation("CategoryFilterPropertyValue", fields: [filterPropertyValueId], references: [id], onDelete: SetNull)
  sectionCategories     SectionCategory[]
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([showInHeader])
  @@index([categoryMode])
  @@index([filterKind])
  @@index([filterPropertyId])
  @@index([filterPropertyValueId])
  @@map("categories")
}

// ---------- Dynamic Properties ----------

model Property {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  hasPhoto  Boolean  @default(false) @map("has_photo")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  values           PropertyValue[]
  productValues    ProductPropertyValue[]
  filterCategories Category[]             @relation("CategoryFilterProperty")

  @@map("properties")
}

model PropertyValue {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  value      String
  slug       String
  photo      String?
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  productValues    ProductPropertyValue[]
  filterCategories Category[]             @relation("CategoryFilterPropertyValue")

  @@unique([propertyId, slug])
  @@index([propertyId, order])
  @@map("property_values")
}

enum CategoryMode {
  MANUAL
  FILTER
}

enum CategoryFilterKind {
  PROPERTY_VALUE
  SALE
}

model ProductPropertyValue {
  id              String   @id @default(cuid())
  productId       String   @map("product_id")
  propertyId      String   @map("property_id")
  propertyValueId String   @map("property_value_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyValue PropertyValue @relation(fields: [propertyValueId], references: [id], onDelete: Cascade)

  @@unique([productId, propertyValueId])
  @@index([propertyId])
  @@index([propertyValueId])
  @@map("product_property_values")
}

// ---------- CMS: Section Types & Home Sections ----------

model SectionType {
  id           String   @id @default(cuid())
  name         String   @unique
  component    String   @unique
  configSchema Json     @default("{}") @map("config_schema")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sections HomeSection[]

  @@map("section_types")
}

model HomeSection {
  id            String      @id @default(cuid())
  sectionTypeId String      @map("section_type_id")
  sectionType   SectionType @relation(fields: [sectionTypeId], references: [id], onDelete: Cascade)
  title         String?
  config        Json        @default("{}")
  order         Int         @default(0)
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([isActive, order])
  @@map("home_sections")
}

model MediaAsset {
  id            String             @id @default(cuid())
  storageKey    String             @unique @map("storage_key")
  originalName  String?            @map("original_name")
  mimeType      String?            @map("mime_type")
  size          Int?
  width         Int?
  height        Int?
  alt           String?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  sectionItems  SectionMediaItem[]

  @@map("media_assets")
}

model Section {
  id          String                 @id @default(cuid())
  pageId      String                 @map("page_id")
  page        Page                   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type        String
  order       Int                    @default(0)
  isActive    Boolean                @default(true) @map("is_active")
  title       String?
  subtitle    String?
  anchor      String?
  background  Json?
  config      Json                   @default("{}")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  products    SectionProduct[]
  categories  SectionCategory[]
  pages       SectionPageReference[]
  mediaItems  SectionMediaItem[]

  @@index([pageId, order])
  @@index([type])
  @@index([isActive])
  @@map("sections")
}

model SectionProduct {
  sectionId   String   @map("section_id")
  productId   String   @map("product_id")
  order       Int      @default(0)
  role        String?

  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([sectionId, productId])
  @@index([sectionId, order])
  @@index([productId])
  @@map("section_products")
}

model SectionCategory {
  sectionId   String    @map("section_id")
  categoryId  String    @map("category_id")
  order       Int       @default(0)
  role        String?

  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([sectionId, categoryId])
  @@index([sectionId, order])
  @@index([categoryId])
  @@map("section_categories")
}

model SectionPageReference {
  sectionId     String   @map("section_id")
  targetPageId  String   @map("target_page_id")
  order         Int      @default(0)
  role          String?

  section       Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  targetPage    Page     @relation("SectionTargetPage", fields: [targetPageId], references: [id], onDelete: Cascade)

  @@id([sectionId, targetPageId])
  @@index([sectionId, order])
  @@index([targetPageId])
  @@map("section_page_references")
}

model SectionMediaItem {
  sectionId     String      @map("section_id")
  mediaAssetId  String      @map("media_asset_id")
  order         Int         @default(0)
  role          String?
  altOverride   String?     @map("alt_override")

  section       Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  mediaAsset    MediaAsset  @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@id([sectionId, mediaAssetId])
  @@index([sectionId, order])
  @@index([mediaAssetId])
  @@map("section_media_items")
}

// ---------- CMS: Settings ----------

model Setting {
  key         String   @id
  value       Json
  type        String   @default("string")
  isPublic    Boolean  @default(true) @map("is_public")
  group       String   @default("general")
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@index([isPublic])
  @@map("settings")
}

model StoreSettings {
  id              Int      @id @default(1)
  phone           String
  additionalPhone String?  @map("additional_phone")
  email           String
  supportEmail    String?  @map("support_email")
  address         String
  city            String?
  postalCode      String?  @map("postal_code")
  workingHours    Json     @default("{}") @map("working_hours")
  socialLinks     Json     @default("[]") @map("social_links")
  aboutUs         String?  @map("about_us")
  legalInfo       Json?    @map("legal_info")
  logoUrl         String?  @map("logo_url")
  faviconUrl      String?  @map("favicon_url")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("store_settings")
}

model Product {
  id             String                   @id @default(cuid())
  name           String
  slug           String                   @unique
  description    String?
  price          Float?
  compareAtPrice Float?                   @map("compare_at_price")
  stock          Int                      @default(0)
  sku            String?                  @unique
  categoryId     String?                  @map("category_id")
  category       Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  rootCategoryId String?                  @map("root_category_id")
  rootCategory   Category?                @relation("ProductRootCategory", fields: [rootCategoryId], references: [id], onDelete: SetNull)
  subcategoryId  String?                  @map("subcategory_id")
  subcategory    Category?                @relation("ProductSubcategory", fields: [subcategoryId], references: [id], onDelete: SetNull)
  isActive       Boolean                  @default(true) @map("is_active")
  brand          String?
  brandCountry   String?                  @map("brand_country")
  rating         Float?
  reviewsCount   Int                      @default(0) @map("reviews_count")
  badges         Json                     @default("[]")
  metaTitle      String?                  @map("meta_title")
  metaDesc       String?                  @map("meta_description")
  searchVector   Unsupported("tsvector")? @map("search_vector")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  userId         String?                  @map("user_id")
  user           User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)

  images          ProductImage[]
  properties      ProductPropertyValue[]
  orderItems      OrderItem[]
  favorites       Favorite[]
  compareItems    CompareItem[]
  productViews    ProductView[]
  sectionProducts SectionProduct[]

  @@index([categoryId])
  @@index([rootCategoryId])
  @@index([subcategoryId])
  @@index([isActive, createdAt(sort: Desc)])
  @@index([brand])
  @@index([searchVector], type: Gin)
  @@map("products")
}

model ProductImage {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url          String
  key          String
  originalName String?  @map("original_name")
  size         Int?
  mimeType     String?  @map("mime_type")
  order        Int      @default(0)
  isMain       Boolean  @default(false) @map("is_main")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@index([productId, isMain])
  @@map("product_images")
}

model Page {
  id                String        @id @default(cuid())
  title             String
  slug              String        @unique
  kind              PageKind      @default(REGULAR)
  status            PageStatus    @default(DRAFT)
  content           String?
  contentBlocks     Json?         @map("content_blocks")
  showAsBanner      Boolean       @default(false) @map("show_as_banner")
  bannerImage       String?       @map("banner_image")
  bannerLink        String?       @map("banner_link")
  isSystem          Boolean       @default(false) @map("is_system")
  image             String?
  imagePath         String?       @map("image_path")
  imageOriginalName String?       @map("image_original_name")
  metaTitle         String?       @map("meta_title")
  metaDesc          String?       @map("meta_description")
  isPublished       Boolean       @default(false) @map("is_published")
  publishedAt       DateTime?     @map("published_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  authorId          String?       @map("author_id")
  author            User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  sections          Section[]
  blocks            PageBlock[]
  referencedBySections SectionPageReference[] @relation("SectionTargetPage")
  versions          PageVersion[]

  @@index([kind])
  @@index([status, publishedAt])
  @@map("pages")
}

model PageBlock {
  id        String   @id @default(cuid())
  pageId    String   @map("page_id")
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String
  order     Int
  isActive  Boolean  @default(true) @map("is_active")
  config    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([pageId, order])
  @@map("page_blocks")
}

model PageVersion {
  id        String   @id @default(cuid())
  pageId    String   @map("page_id")
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title     String
  content   String?
  image     String?
  metaTitle String?  @map("meta_title")
  metaDesc  String?  @map("meta_description")
  slugSnapshot String? @map("slug_snapshot")
  statusSnapshot String? @map("status_snapshot")
  sectionsSnapshot Json? @map("sections_snapshot")
  blocksSnapshot Json? @map("blocks_snapshot")
  seoSnapshot Json? @map("seo_snapshot")
  version   Int
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  @@unique([pageId, version])
  @@map("page_versions")
}

model AnonymousSession {
  id        String   @id @default(cuid())
  sessionId String   @unique @map("session_id")
  cart      Json     @default("{}")
  favorites Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userId    String?  @unique @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("anonymous_sessions")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("carts")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@map("favorites")
}

model Order {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    OrderStatus @default(PENDING)
  contactMethod ContactMethod @default(PHONE) @map("contact_method")
  total     Float
  address   String?
  phone     String?
  comment   String?
  items     OrderItem[]
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Float
  createdAt DateTime @default(now()) @map("created_at")

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ContactMethod {
  PHONE
  VIBER
}

model CompareItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@map("compare_items")
}

model Webhook {
  id        String   @id @default(cuid())
  url       String
  events    String[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("webhooks")
}

// ---------- SEO Metadata ----------

model SeoMetadata {
  id            String   @id @default(cuid())
  targetType    String   @map("target_type")
  targetId      String   @map("target_id")
  title         String?
  description   String?
  keywords      String?
  ogTitle       String?  @map("og_title")
  ogDescription String?  @map("og_description")
  ogImage       String?  @map("og_image")
  canonicalUrl  String?  @map("canonical_url")
  noIndex       Boolean  @default(false) @map("no_index")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([targetType, targetId])
  @@index([targetType])
  @@map("seo_metadata")
}

// ---------- Recommendation system ----------

model ProductView {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  sessionId String   @map("session_id")
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now()) @map("viewed_at")

  @@unique([sessionId, productId])
  @@index([userId, viewedAt])
  @@index([sessionId, viewedAt])
  @@index([productId, viewedAt])
  @@map("product_views")
}

model SearchQuery {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  sessionId String   @map("session_id")
  query     String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([query, createdAt])
  @@map("search_queries")
}

// ---------- Push Notifications ----------

enum PushPlatform {
  FCM
  WEB_PUSH
}

model PushDevice {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  PushPlatform
  token     String       @unique
  endpoint  String?
  p256dh    String?
  authKey   String?      @map("auth_key")
  active    Boolean      @default(true)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([userId])
  @@index([platform])
  @@map("push_devices")
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  desc      String
  meta      Json?
  isRead    Boolean  @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([isRead, createdAt])
  @@map("notifications")
}

model ImportOperation {
  id        String   @id @default(cuid())
  type      String
  count     Int      @default(0)
  status    String   @default("COMPLETED")
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@map("import_operations")
}
