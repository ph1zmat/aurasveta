{
  "expo": {
    "name": "Аура Света CMS",
    "slug": "auracms",
    "scheme": "aurasveta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0E8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "ru.aurasveta.cms",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F0E8"
      },
      "permissions": [
        "NOTIFICATIONS",
        "INTERNET"
      ],
      "googleServicesFile": "./google-services.json",
      "allowBackup": false,
      "enableEdgeToEdge": true
    },
    "ios": {
      "bundleIdentifier": "ru.aurasveta.cms",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Для загрузки фотографий товаров",
        "NSPhotoLibraryUsageDescription": "Для выбора фотографий товаров"
      }
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      "expo-sharing",
      "expo-navigation-bar",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "useLegacyPackaging": false
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "0521569e-d8d4-4491-b8a7-f41f2142bd88"
      }
    },
    "owner": "ph1zpunk"
  }
}
