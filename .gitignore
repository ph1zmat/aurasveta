!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# desktop
/desktop

# mobile
/mobile

# screenshots / temp images
emulator_*.png
screenshots/
design-output.html
/public/download

# misc IDE / OS
.idea/
.vscode/

# temporary / backup files
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
*~

# temporary work directories
temp/
tmp/
backup/
drafts/
wip/
scratch/
archive/

# draft / planning artifacts
**/*_plan.md
**/draft*.md
**/*wip*.md

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# local desktop runtime artifacts
/desktop/stderr.log
/dev-log.txt

# local logs
logs/

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# Исключить файлы с реальными секретами
VPS_PROD_ENV.md
HOSTER_API.md

# исключить всю документацию кроме README
docs/**
!docs/README.md

# импорт фото: большие файлы данных и скачанные фото
data

scripts/import